{
	"name": "@yukukotani/ncli",
	"version": "0.3.3",
	"description": "CLI for Notion — MCP + REST API support",
	"type": "module",
	"bin": {
		"ncli": "dist/index.js"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup src/index.ts --format esm --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build && npm run typecheck && npm run lint && npm test"
	},
	"engines": {
		"node": ">=18"
	},
	"author": "Sakasegawa",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yuku-contrib/notion-cli.git"
	},
	"homepage": "https://github.com/yuku-contrib/notion-cli#readme",
	"bugs": {
		"url": "https://github.com/yuku-contrib/notion-cli/issues"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org",
		"access": "public"
	},
	"keywords": [
		"notion",
		"ncli",
		"cli",
		"mcp",
		"model-context-protocol",
		"notion-api"
	],
	"files": [
		"dist"
	],
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.1",
		"commander": "^14.0.3",
		"env-paths": "^4.0.0",
		"open": "^11.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/node": "^25.5.0",
		"lefthook": "^2.1.4",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	}
}
